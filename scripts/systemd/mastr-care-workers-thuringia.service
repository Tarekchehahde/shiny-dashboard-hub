[Unit]
Description=MaStR dashboard care_workers_thuringia (research)
After=network.target

[Service]
Type=simple
User=rstudio
WorkingDirectory=/opt/mastr-shiny/WORK/shiny/apps/care_workers_thuringia
Environment=HOME=/home/rstudio
Environment=MASTR_HUB_MODE=paths
ExecStart=/usr/lib/R/bin/R -e "options(shiny.url.pathPrefix='/care_workers_thuringia'); shiny::runApp('.', host='0.0.0.0', port=3855, launch.browser=FALSE)"
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
