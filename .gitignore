# =============================================================
# MaStR monorepo — never commit raw or derived data
# =============================================================

# Raw / derived data at repo root (generated by ETL, local experiments).
# Use leading slash so THESIS/thesis_energy_mastr_shiny/data/ stays trackable.
/data/
/data-raw/
/data-parquet/
/data-duckdb/
*.xml
*.xml.zip
*.parquet
*.duckdb
*.duckdb.wal

# Python / ETL (under WORK/)
WORK/etl/.venv/
WORK/etl/__pycache__/
WORK/etl/**/__pycache__/
WORK/etl/**/*.pyc
WORK/etl/.pytest_cache/
WORK/etl/.ruff_cache/
WORK/etl/.mypy_cache/
WORK/etl/dist/
WORK/etl/build/
WORK/etl/*.egg-info/

# R / Shiny (WORK production apps)
WORK/shiny/.Rhistory
WORK/shiny/.RData
WORK/shiny/.Rproj.user/
WORK/shiny/renv/library/
WORK/shiny/renv/local/
WORK/shiny/renv/staging/
WORK/shiny/renv/python/

# THESIS renv (if used)
THESIS/thesis_energy_mastr_shiny/.Rhistory
THESIS/thesis_energy_mastr_shiny/.RData
THESIS/thesis_energy_mastr_shiny/.Rproj.user/
THESIS/thesis_energy_mastr_shiny/renv/library/
THESIS/thesis_energy_mastr_shiny/renv/local/
THESIS/thesis_energy_mastr_shiny/renv/staging/

# shinylive / pages build
_site/
shinylive-site/

# OS junk
.DS_Store
Thumbs.db

# Local launch logs (Mac)
logs/*.log

# Editors
.vscode/
.idea/

WORK/shiny/apps/**/.RData
WORK/shiny/apps/**/.Rhistory

# Private PhD reference tooling (methodology doc OK; outputs/cache never commit)
WORK/docs/References_PhD*
WORK/docs/.scholar*
WORK/docs/.author_year*
WORK/docs/build_scholar*
WORK/docs/export_references*
WORK/docs/scholar_build.log
WORK/docs/__pycache__/

# Local-only server credentials (never commit)
WORK/docs/SERVER.credentials.local.md
WORK/docs/*.credentials.local.md
WORK/docs/*.local.md
